{
  "name": "@edu/api",
  "version": "0.1.0",
  "description": "A basic starter for an express.js v5 API with Typescript",
  "author": "CJ R. <cj@null.computer> (https://w3cj.now.sh)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/w3cj/express-api-starter-ts.git"
  },
  "keywords": [],
  "main": "src/index.ts",
  "scripts": {
    "start": "node --env-file=.env.local dist/src/index.js",
    "dev": "tsx watch --env-file=.env.local src/index.ts",
    "build": "tsc",
    "lint": "eslint --fix src test",
    "test": "vitest run --exclude dist/**",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx --env-file=.env prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@langchain/core": "^1.1.34",
    "@langchain/openai": "^1.3.0",
    "@langchain/textsplitters": "^1.0.1",
    "@prisma/client": "^6.0.0",
    "@qdrant/js-client-rest": "1.13.0",
    "ai": "^6.0.116",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^1.2.35",
    "mammoth": "^1.12.0",
    "marked": "^17.0.4",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "prisma": "^6.0.0",
    "uuid": "^13.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.2.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/marked": "^6.0.0",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.9.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.5",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^11.0.0",
    "eslint": "^9.38.0",
    "eslint-plugin-format": "^1.0.2",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.6"
  },
  "private": "true",
  "prisma": {
    "seed": "tsx --env-file=.env prisma/seed.ts"
  }
}
